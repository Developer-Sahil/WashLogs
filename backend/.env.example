# WashLogs Backend Environment Variables
# Copy this file to .env and fill in the values

# API Configuration
API_TITLE="WashLogs API"
API_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT="development"

# Server Configuration
HOST="0.0.0.0"
PORT=8000

# Supabase Configuration
# You can find these in your Supabase project settings under Settings > API
SUPABASE_URL="your-supabase-url"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database Configuration
# Format: postgresql://user:password@host:port/dbname
# For local development with SQLite, use: sqlite:///./washlogs.db
DATABASE_URL="sqlite:///./washlogs.db"

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
